# kotoji environment template. Copy to `.env` and adjust.
# Every backend variable uses the KOTOJI_ prefix (see docs/architecture.md §6).
# Values here are safe DEV defaults; production must override the marked ones.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
# development | production. Production enables fail-fast validation.
KOTOJI_ENV=development
# all | control | serve. `all` runs both planes in one process (self-host default).
KOTOJI_RUN_MODE=all
# Control-plane (API/auth/MCP) listen address.
KOTOJI_CONTROL_ADDR=:8080
# Data-plane (static hosting) listen address.
KOTOJI_SERVE_ADDR=:8081

# ---------------------------------------------------------------------------
# Domains / URLs  (REQUIRED to real values in production)
# ---------------------------------------------------------------------------
# Base for {handle}[--{branch}].<base> subdomain parsing.
KOTOJI_BASE_DOMAIN=hosting.localhost
# External URL of the control host (OIDC redirect, cookies, links). This is the
# SINGLE-ORIGIN URL a browser uses, so it must match how the edge publishes the
# control host — NOT an internal plane port. The local Quick start runs the edge
# overlay (docker-compose.edge.yml) in HTTP mode, which fronts the bare host on
# :80, so the dev default has no port. (Behind your own proxy, set this to the
# public URL your proxy serves; in production use your real https URL.)
# Its hostname (no port) becomes the host-only session-cookie domain.
KOTOJI_CONTROL_BASE_URL=http://hosting.localhost

# ---------------------------------------------------------------------------
# kotoji-native on-demand TLS  (the THIRD deploy mode; see deploy/README.md)
# ---------------------------------------------------------------------------
# Read ONLY when you bring up the native-TLS overlay:
#   docker compose -f docker-compose.yml -f docker-compose.tls.yml up -d
# In this mode kotoji TERMINATES TLS ITSELF (CertMagic on-demand): it binds :443
# (single combined control+data handler) + :80 (ACME HTTP-01 + HTTPS redirect) and
# issues a PER-HOST cert on the fly the first time a handshake arrives for a host it
# is authoritative for (the control host, or an EXISTING hosted site/preview).
# NO external proxy, NO wildcard cert, NO DNS-01 token, NO ACME secret in env.
# MUTUALLY EXCLUSIVE with the Traefik edge overlay (docker-compose.edge.yml).
#
# off (DEFAULT — plain HTTP behind your own proxy / the Traefik overlay) | auto.
# The overlay sets this to `auto`; leave it `off` for the base/edge deployments.
KOTOJI_TLS_MODE=off
# prod (real Let's Encrypt certs) | staging (untrusted TEST certs, generous rate
# limits). Use staging to validate the on-demand flow before issuing real certs.
KOTOJI_TLS_CA=prod
# OPTIONAL Let's Encrypt account email (shared with the edge overlay below). May be
# empty — on-demand issuance works without it; set it later via env or the UI.
KOTOJI_ACME_EMAIL=
# Advanced: override the native-TLS listen addresses (defaults :443 / :80).
# KOTOJI_TLS_ADDR=:443
# KOTOJI_TLS_HTTP_ADDR=:80

# ---------------------------------------------------------------------------
# Edge / Traefik  (ONLY for the opt-in all-in-one overlay; see deploy/README.md)
# ---------------------------------------------------------------------------
# These are read ONLY when you bring up the bundled edge:
#   docker compose -f docker-compose.yml -f docker-compose.edge.yml up -d
# The base compose ignores everything in this block. Leave it as-is for the
# HTTP/localhost default; uncomment the HTTPS profile at the bottom for prod TLS.
#
# Same domain as KOTOJI_BASE_DOMAIN but with the literal dots escaped for the
# Go regexp that matches 2-level hosted-site hosts ({handle}.<base>).
#   hosting.localhost -> hosting\.localhost ;  example.com -> example\.com
KOTOJI_BASE_DOMAIN_REGEX=hosting\.localhost
#
# Traefik dashboard (insecure, local only). Reachable on KOTOJI_TRAEFIK_DASHBOARD_PORT.
KOTOJI_TRAEFIK_DASHBOARD=false
KOTOJI_TRAEFIK_DASHBOARD_PORT=8082
KOTOJI_TRAEFIK_LOG_LEVEL=INFO
#
# --- TLS profile selector ---------------------------------------------------
# DEFAULT = HTTP only (no certs) — perfect for localhost / first run. Routers
# bind to the `web` entrypoint, no redirect, no ACME resolver requested.
KOTOJI_EDGE_ENTRYPOINTS=web
KOTOJI_EDGE_TLS=false
KOTOJI_EDGE_CERTRESOLVER=
KOTOJI_EDGE_REDIRECT_TO=web
KOTOJI_EDGE_REDIRECT_SCHEME=http
#
# ACME (Let's Encrypt) — leave EMPTY for HTTP-only. Filling these in is REQUIRED
# to switch on the HTTPS profile below; DNS-01 is mandatory because hosted sites
# need a WILDCARD cert (*.${KOTOJI_BASE_DOMAIN}).
# (KOTOJI_ACME_EMAIL is shared with the native-TLS block above — set it once.)
KOTOJI_ACME_DNS_PROVIDER=cloudflare
# Cloudflare API token scoped to Zone:DNS:Edit for the zone. Other providers:
# set KOTOJI_ACME_DNS_PROVIDER to your provider and pass its token env yourself.
KOTOJI_CF_DNS_API_TOKEN=
#
# --- To enable HTTPS in production, set KOTOJI_BASE_DOMAIN to your real domain,
#     fill KOTOJI_ACME_EMAIL + KOTOJI_CF_DNS_API_TOKEN above, then replace the
#     five HTTP-profile lines with these (uncomment): -----------------------
# KOTOJI_EDGE_ENTRYPOINTS=websecure
# KOTOJI_EDGE_TLS=true
# KOTOJI_EDGE_CERTRESOLVER=letsencrypt
# KOTOJI_EDGE_REDIRECT_TO=websecure
# KOTOJI_EDGE_REDIRECT_SCHEME=https

# ---------------------------------------------------------------------------
# Database (REQUIRED in production)
# ---------------------------------------------------------------------------
# pgx DSN. In compose, host=postgres. Use a strong password in production.
KOTOJI_DATABASE_URL=postgres://kotoji:kotoji@postgres:5432/kotoji?sslmode=disable
KOTOJI_DB_MAX_CONNS=10

# Postgres container credentials (consumed by the postgres service).
POSTGRES_USER=kotoji
POSTGRES_PASSWORD=kotoji
POSTGRES_DB=kotoji

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
# Root for sites/, published/, tmp/ (mounted as a volume in compose).
KOTOJI_DATA_DIR=/data
# Path to the git binary (present in the backend runtime image).
KOTOJI_GIT_BIN=git

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
# Providers to enable. A single value (oidc | password | none) OR a comma-set to
# run several at once, e.g. `oidc,password` = Google login PLUS a break-glass
# admin password. `none` is dev-only (rejected in production) and is exclusive.
# The dev default is `password`: with KOTOJI_AUTH_ADMIN_PASSWORD left empty below,
# the first run shows the admin-password SETUP screen (you pick the password in
# the browser). Set it to `none` for fully open local access, or `oidc` for Google.
KOTOJI_AUTH_MODE=password

# --- oidc provider (Google by default) ---
KOTOJI_OIDC_ISSUER=https://accounts.google.com
KOTOJI_OIDC_CLIENT_ID=
KOTOJI_OIDC_CLIENT_SECRET=
# Redirect URI registered in Google. Defaults to
# ${KOTOJI_CONTROL_BASE_URL}/auth/callback when left empty.
KOTOJI_OIDC_REDIRECT_URL=
# Access control — FAIL-CLOSED: with oidc enabled you MUST set at least one of
# these or the backend refuses to boot. Sign-in is allowed iff the verified email
# is in ALLOWED_EMAILS *or* its domain is in ALLOWED_DOMAINS (both comma lists).
KOTOJI_OIDC_ALLOWED_EMAILS=
KOTOJI_OIDC_ALLOWED_DOMAINS=
# Verified emails listed here are promoted to instance admin (is_admin) on login.
KOTOJI_OIDC_ADMIN_EMAILS=
# Legacy aliases still honored: KOTOJI_AUTH_OIDC_CLIENT_ID/SECRET/ISSUER/
# REDIRECT_URL, KOTOJI_AUTH_GOOGLE_HD (single domain), KOTOJI_AUTH_ALLOWED_EMAILS.

# --- password mode ---
KOTOJI_AUTH_ADMIN_PASSWORD=
KOTOJI_AUTH_ADMIN_EMAIL=admin@kotoji.local

# ---------------------------------------------------------------------------
# Session / cookies
# ---------------------------------------------------------------------------
KOTOJI_SESSION_COOKIE_NAME=kotoji_session
# Go duration string. 720h = 30d.
KOTOJI_SESSION_TTL=720h
# Defaults to the bare control host (host-only). Must NOT be the wildcard parent.
KOTOJI_SESSION_COOKIE_DOMAIN=
# Secure cookie attribute on the __Host- session/CSRF cookies (the sole
# cross-subdomain isolation control). MUST be true in production — Load refuses to
# boot with KOTOJI_COOKIE_SECURE=false when KOTOJI_ENV=production (fail-closed).
# The dev default is false because the local Quick start runs the edge overlay in
# plain HTTP; a Secure cookie would never be sent back over http, so the session
# would not stick. FLIP TO true (and use https) for any real deployment.
KOTOJI_COOKIE_SECURE=false
KOTOJI_CSRF_COOKIE_NAME=kotoji_csrf

# ---------------------------------------------------------------------------
# MCP
# ---------------------------------------------------------------------------
KOTOJI_MCP_ENABLED=true
KOTOJI_MCP_PATH=/mcp
# Default project-token lifetime. 2160h = 90d.
KOTOJI_MCP_TOKEN_TTL=2160h

# ---------------------------------------------------------------------------
# At-rest encryption key (REQUIRED in production)
# ---------------------------------------------------------------------------
# Master key that encrypts secrets at rest in the database (the GitHub mirror PAT
# and the OIDC client secret) via AES-256-GCM. Provide either 64 hex chars or
# base64 that decodes to >= 32 bytes; only the first 32 bytes are used.
#
# FAIL-CLOSED (H2): in production the backend REFUSES TO BOOT without this key.
# When it is unset, the key is otherwise DERIVED from low-entropy, partly-public
# config inputs (admin-password hash | OIDC secret | control base URL | base
# domain), so anyone who knows those inputs could reproduce the key and decrypt
# stored secrets. The derived fallback is allowed in DEVELOPMENT only.
#
# Rotating this key makes previously-stored secrets undecryptable (Open fails
# closed -> the admin simply re-enters the GitHub PAT / OIDC secret once).
# Generate with: openssl rand -hex 32
KOTOJI_SECRET_KEY=

# ---------------------------------------------------------------------------
# GitHub mirror (optional). When enabled, token + webhook secret are required.
# ---------------------------------------------------------------------------
KOTOJI_GITHUB_MIRROR_ENABLED=false
KOTOJI_GITHUB_APP_TOKEN=
KOTOJI_GITHUB_PAT=
KOTOJI_GITHUB_ORG=
# HMAC-SHA256 secret verified on POST /api/webhooks/github (X-Hub-Signature-256).
# REQUIRED when the mirror is enabled; the webhook route is only mounted then.
# Generate with: openssl rand -hex 32
KOTOJI_GITHUB_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Upload / zip guards (security-critical)
# ---------------------------------------------------------------------------
# 50MB hard cap on the uploaded zip (pre-extract).
KOTOJI_MAX_UPLOAD_BYTES=52428800
# 200MB cap on total uncompressed size.
KOTOJI_ZIP_MAX_TOTAL_BYTES=209715200
KOTOJI_ZIP_MAX_FILES=2000
# 50MiB per-entry uncompressed cap (a single file inside the zip). Raise this to
# allow a larger single asset; lower it to tighten the per-file zip-bomb guard.
KOTOJI_ZIP_MAX_ENTRY_BYTES=52428800
# Zip-bomb guard: max uncompressed/compressed ratio.
KOTOJI_ZIP_MAX_RATIO=100
KOTOJI_ZIP_ALLOWED_EXT=.html,.htm,.css,.js,.mjs,.json,.svg,.png,.jpg,.jpeg,.gif,.webp,.ico,.woff,.woff2,.ttf,.txt,.md,.map,.xml,.csv,.wasm

# ---------------------------------------------------------------------------
# Quotas / rate limits
# ---------------------------------------------------------------------------
# 500MB per-site disk quota.
KOTOJI_SITE_QUOTA_BYTES=524288000
KOTOJI_USER_SITE_QUOTA=50
# Per-session/IP rate limit on the control API (auth + writes + uploads). 0 = off.
KOTOJI_RATE_LIMIT_API_RPS=20
# Per-IP rate limit on the data plane (served content). 0 = off.
KOTOJI_RATE_LIMIT_SERVE_RPS=100

# Cache-Control max-age (SECONDS) for NON-HTML served assets (CSS/JS/images/fonts).
# Default 0 (or any value <=0) => the data plane emits "no-cache": clients store the
# asset but revalidate every time, so a re-publish or an operator "Clear cache" is
# seen IMMEDIATELY via the commit+cache-version ETag and cheap 304s (no returning
# visitor serves stale CSS/JS). Set a positive value to opt into "public, max-age=N"
# and accept up to N seconds of staleness in exchange for fewer revalidations.
KOTOJI_ASSET_MAX_AGE=0

# ---------------------------------------------------------------------------
# Operability / background jobs (architecture.md §8.4, decision #3)
# ---------------------------------------------------------------------------
# Retention before the soft-delete reaper bundles + reclaims a deleted site.
# Go duration string. 720h = 30d.
KOTOJI_SOFT_DELETE_GRACE=720h
# Where `git bundle` backups are written before the on-disk repo is removed.
# Defaults to ${KOTOJI_DATA_DIR}/backups when empty.
KOTOJI_BACKUP_DIR=
# Background ops scheduler tick (reaper + git gc --auto). Go duration string.
KOTOJI_OPS_INTERVAL=1h

# ---------------------------------------------------------------------------
# CORS / handles / behavior
# ---------------------------------------------------------------------------
# Comma-separated origins. Empty defaults to ${KOTOJI_CONTROL_BASE_URL}.
KOTOJI_CORS_ALLOWED_ORIGINS=
KOTOJI_HANDLE_MIN_LEN=2
KOTOJI_HANDLE_MAX_LEN=40
# Serve published content without auth.
KOTOJI_PUBLISHED_PUBLIC=true
# Trust X-Forwarded-* (only behind the known proxy).
KOTOJI_TRUST_PROXY_HEADERS=true

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# debug | info | warn | error.
KOTOJI_LOG_LEVEL=info
# json | text.
KOTOJI_LOG_FORMAT=json

# ---------------------------------------------------------------------------
# Frontend (Next.js). NEXT_PUBLIC_* ships to the browser — keep them safe.
# ---------------------------------------------------------------------------
# Base for API calls. Empty => same-origin relative /api (via the proxy).
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_APP_NAME=kotoji
# Tells the UI which sign-in affordance to render. Keep this in sync with the
# backend KOTOJI_AUTH_MODE above (here: password => the setup/sign-in screen).
NEXT_PUBLIC_AUTH_MODE=password
NEXT_PUBLIC_DEFAULT_THEME=system
# Next standalone listen port.
PORT=3000
